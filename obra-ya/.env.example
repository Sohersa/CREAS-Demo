# =============================================
# ObraYa — Variables de Entorno
# =============================================
# Copia este archivo como .env y llena los valores

# Anthropic API (para el agente de IA)
ANTHROPIC_API_KEY=sk-ant-xxxxxxx

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=tu_token_aqui
WHATSAPP_PHONE_ID=tu_phone_id
WHATSAPP_VERIFY_TOKEN=tu_verify_token_seguro

# Twilio WhatsApp (fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
WHATSAPP_PROVIDER=meta

# Base de datos
# Dev: sqlite:///./obra_ya.db
# Prod (Railway): postgresql://user:pass@host:5432/railway
DATABASE_URL=sqlite:///./obra_ya.db

# Stripe (pagos)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Auth / JWT
JWT_SECRET=tu_secret_seguro_minimo_32_chars
JWT_EXPIRE_HOURS=72

# Entorno
ENVIRONMENT=development
LOG_LEVEL=debug
